# Variables requeridas
NODE_ENV=production
PORT=3001

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/licoreria369?retryWrites=true&w=majority

# JWT - genera uno aleatorio:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_un_string_aleatorio_largo

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# Orígenes permitidos para CORS, separados por coma.
# Apps nativas no requieren orígenes; solo navegadores web.
ALLOWED_ORIGINS=https://tu-dominio.com
