{
  "expo": {
    "name": "Licorería 369",
    "slug": "licoreria-369",
    "version": "1.0.0",
    "description": "Catálogo digital de Licorería 369. Explora vinos, licores, cervezas y más. Solo para mayores de 18 años.",
    "primaryColor": "#7a7820",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.licoreria369.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Solo el panel de administración usa fotos para subir imágenes de productos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.licoreria369.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0a"
      },
      "edgeToEdgeEnabled": false,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Solo el panel de administración usa fotos para subir imágenes de productos."
        }
      ],
      "@sentry/react-native"
    ],
    "scheme": "licoreria369",
    "extra": {
      "eas": {
        "projectId": "85ac8915-9b02-4ced-864e-51f4568cac57"
      },
      "router": {}
    },
    "owner": "ivanyhe"
  }
}
